@using SkillSnap.Client
@using SkillSnap.Shared.Models
@inherits LayoutComponentBase

@code {
    [Parameter]
    public PortfolioUserDto? User { get; set; }
}

@if (User is null)
{
    <div class="profile-card">No profile data available.</div>
}
else
{
<div class="profile-card">
    <img src="@User.ProfileImageUrl" alt="Profile Picture" class="profile-picture" />
    <h2>@User.Name</h2>
    <p>@User.Bio</p>
    <img src="@User.ProfileImageUrl" />
    <SkillTags Skills="@User.Skills" />
    <ProjectList Projects="@User.Projects" />
</div>
}

<style>
.profile-card {
    border: 1px solid #ccc;
    padding: 16px;
    width: 300px;
    text-align: center;
    border-radius: 8px;
    background: #fff;
}
.profile-picture {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 12px;
}
</style>